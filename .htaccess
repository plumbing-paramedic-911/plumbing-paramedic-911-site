# ────────────────────────────────────────────────────────────
# Plumbing Paramedic 911 — Apache config (Namecheap / cPanel)
# ────────────────────────────────────────────────────────────

# Default doc + directory index
DirectoryIndex index.html

# Charset
AddDefaultCharset UTF-8

# Disable directory listing
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Strip "www." so the canonical host is the apex
  RewriteCond %{HTTP_HOST} ^www\.plumbingparamedic911\.com$ [NC]
  RewriteRule ^(.*)$ https://plumbingparamedic911.com/$1 [L,R=301]

  # 3. Force trailing slash on directory-style URLs (skip files with extensions)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{1,5}$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # 4. Legacy / old SPA hash routes → real URLs (best-effort; hash isn't sent to server,
  #    but if any link uses ?page= parameters they redirect here)
  RewriteCond %{QUERY_STRING} ^page=pricing$
  RewriteRule ^$ /pricing/? [L,R=301]
  RewriteCond %{QUERY_STRING} ^page=about$
  RewriteRule ^$ /about/? [L,R=301]
  RewriteCond %{QUERY_STRING} ^page=contact$
  RewriteRule ^$ /contact/? [L,R=301]
  RewriteCond %{QUERY_STRING} ^page=services-index$
  RewriteRule ^$ /services/? [L,R=301]
  RewriteCond %{QUERY_STRING} ^page=areas-index$
  RewriteRule ^$ /service-areas/? [L,R=301]
</IfModule>

# ────────────────────────────────────────────────────────────
# Performance: caching + compression
# ────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/avif                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  # MIME-sniffing / type confusion protection
  Header set X-Content-Type-Options "nosniff"
  # Clickjacking protection — only allow framing from same origin
  Header set X-Frame-Options "SAMEORIGIN"
  # Referrer policy — keep origin on cross-origin requests but never full URL
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # Lock down powerful browser APIs (we use none of these)
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=()"
  # Cross-origin isolation hardening
  Header set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  Header set Cross-Origin-Resource-Policy "same-site"
  # HSTS — 2 years, includeSubDomains, preload-ready (only over HTTPS)
  Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" "expr=%{HTTPS} == 'on'"
  # CSP — minimum-viable: upgrade any accidental http:// references; allow self + Google Fonts + GA4
  Header set Content-Security-Policy "upgrade-insecure-requests; default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"

  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js|png|jpg|jpeg|webp|avif|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Don't leak server identity / version
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# Reduce server fingerprinting in Apache responses
ServerSignature Off

# Block direct access to source / docs / config files that shouldn't be served
<FilesMatch "(^\.|\.(env|git|gitignore|gitattributes|md|py|sh|bak|swp|log|sql|toml|yml|yaml|lock|ini|conf|htaccess|htpasswd)$)">
  Require all denied
</FilesMatch>
# Block any path starting with a dot (e.g. .git/, .env), except .well-known/
<IfModule mod_alias.c>
  RedirectMatch 403 (?i)/\.(?!well-known/)
</IfModule>

# Custom MIME types
AddType application/manifest+json .webmanifest
AddType image/svg+xml             .svg
AddType image/webp                .webp
AddType image/avif                .avif

# 404
ErrorDocument 404 /404.html
